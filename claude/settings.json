{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Read(*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(sips:*)",
      "Bash(find:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "mcp__grafana__list_datasources",
      "mcp__grafana__list_loki_label_values",
      "mcp__grafana__query_loki_logs",
      "mcp__grafana__query_prometheus"
    ],
    "deny": [
      "Bash(find *-exec*)",
      "Bash(mv:*)",
      "Bash(aws:*)",
      "Bash(kubectl:*)",
      "Bash(tsh:*)",
      "Bash(dd:*)",
      "Bash(sudo:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(ftp:*)"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(cp:*)",
      "Bash(brew:*)"
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "interface-design@interface-design": true,
    "gopls-lsp@claude-plugins-official": true,
    "prompts.chat@prompts.chat": true,
    "code-review@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "spinnerTipsEnabled": true,
  "teammateMode": "Split panes"
}
